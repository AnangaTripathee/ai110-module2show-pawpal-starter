classDiagram
    class Owner {
        +int owner_id
        +string name
        +string email
        +List~Pet~ pets
        +add_pet(pet)
        +get_pets()
        +get_all_tasks()
    }

    class Pet {
        +int pet_id
        +string name
        +string species
        +string breed
        +Date birthdate
        +string medical_notes
        +List~Task~ tasks
        +get_age()
        +add_task(task)
    }

    class Task {
        +int task_id
        +int pet_id
        +TaskType task_type
        +DateTime scheduled_time
        +int duration_minutes
        +Recurrence recurrence
        +int priority
        +bool completed
        +mark_complete()
        +end_time()
        +is_overdue(now)
        +conflicts_with(other_task)
    }

    class Scheduler {
        +Owner owner
        +add_task(task)
        +complete_task(task, now)
        +get_tasks_for_pet(pet_id)
        +get_todays_tasks(now)
        +detect_conflicts()
        +sort_by_priority()
        +sort_by_time()
        +filter_tasks(pet_id, completed)
        -_next_task_id()
    }

    class TaskType {
        <<enumeration>>
        FEEDING
        WALK
        MEDICATION
        APPOINTMENT
    }

    class Recurrence {
        <<enumeration>>
        NONE
        DAILY
        WEEKLY
    }

    Owner "1" *-- "many" Pet : owns
    Pet "1" *-- "many" Task : owns
    Scheduler "1" --> "1" Owner : reads tasks through
    Scheduler ..> Task : orders / filters / completes
    Task ..> TaskType : uses
    Task ..> Recurrence : uses
